{
  "version": 2,
  "installCommand": "cd backend && npm install",
  "buildCommand": "echo 'No build step needed - serving static frontend'",
  "framework": null,
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "backend/server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" }
  ]
}
